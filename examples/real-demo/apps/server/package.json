{
  "name": "@real-demo/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "db:migrate": "bash scripts/apply-migrations.sh",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:test": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --force && pnpm prisma:seed",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "dev": "nest start --watch",
    "generate": "pnpm prisma:generate && pnpm openapi",
    "lint": "eslint src --ext .ts",
    "openapi": "tsx scripts/export-openapi.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "start": "node dist/main.js",
    "test": "pnpm test:prepare-e2e && vitest run",
    "test:prepare-e2e": "pnpm --dir ../.. exec turbo run build --filter=@real-demo/web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@nestjs/common": "^11.1.21",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@real-demo/shared": "workspace:*",
    "ai": "^6.0.182",
    "better-auth": "^1.6.11",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "svg-captcha": "^1.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@real-demo/config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
