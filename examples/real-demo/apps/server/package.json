{
  "name": "@real-demo/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "db:migrate": "bash scripts/apply-migrations.sh",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:test": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema prisma/schema.prisma --force --skip-generate --skip-seed && pnpm prisma:seed",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "dev": "nest start --watch",
    "generate": "pnpm prisma:generate && pnpm openapi",
    "lint": "eslint src --ext .ts",
    "openapi": "tsx scripts/export-openapi.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.19.3",
    "@real-demo/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pino": "^9.12.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.2",
    "redis": "^5.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.8",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
