APP_BASE_PATH=/
APP_RUNTIME_API_BASE_URL=
NODE_ENV=development
PORT=13000
DATABASE_URL=mysql://app:app@localhost:13306/real_demo
REDIS_URL=redis://localhost:16379
CORS_ORIGIN=http://localhost:14000
LOG_LEVEL=info
SWAGGER_ENABLED=true
# Full external URL of this server (e.g. https://api.example.com). Required in production;
# defaults to http://localhost:PORT in development.
BETTER_AUTH_URL=
# Secret used by BetterAuth to sign session tokens and cookies. Required in production;
# generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Enable the dev-only quick-login bypass (auto-disabled in production)
AUTH_DEV_LOGIN_ENABLED=true
# OAuth provider credentials (optional — omit to disable social sign-in)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# 32-byte key (base64) used to encrypt provider API keys at rest. The server
# refuses to boot until this is set to a real 32-byte base64 key — the
# placeholder below does NOT decode to 32 bytes on purpose, so misconfiguration
# fails loudly instead of silently writing recoverable ciphertext.
# `make setup` substitutes this placeholder with a fresh openssl-generated key
# in apps/server/.env. To rotate manually: openssl rand -base64 32
# WARNING: losing this key makes every encrypted provider API key unrecoverable.
REAL_DEMO_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
# Set to match your reverse-proxy chain. Examples: loopback | loopback,linklocal,uniquelocal | 1
TRUST_PROXY=false
