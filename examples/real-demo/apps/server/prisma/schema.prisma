generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  // id is a cuid string — serves as both the internal PK and the public
  // user identifier (previously split across `id: Int` and `userId: String`).
  id            String     @id @default(cuid()) @map("user_id")
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false) @map("email_verified")
  image         String     @default("") @db.VarChar(512)
  username      String     @unique
  role          UserRole   @default(USER)
  department    Json       @default("[]")
  status        UserStatus @default(ACTIVE)
  lastLogin     DateTime?  @map("last_login")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@map("user")
}

// BetterAuth-managed session table. `token` stores the raw session token;
// BetterAuth handles its own signing/validation internally.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @default("") @map("ip_address") @db.VarChar(64)
  userAgent String?  @default("") @map("user_agent") @db.VarChar(512)
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

// BetterAuth-managed account table. Stores both credential accounts (password)
// and OAuth accounts (accessToken, refreshToken, etc.).
model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(128)
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.VarChar(1024)
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, providerId], name: "account_account_provider_uk")
  @@index([userId])
  @@map("account")
}

// Used by BetterAuth for email verification tokens, password-reset tokens, etc.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verification")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(128)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_setting")
}

model Provider {
  id             Int       @id @default(autoincrement())
  providerKey    String    @unique @map("provider_key") @db.VarChar(64)
  name           String    @db.VarChar(128)
  type           String    @db.VarChar(32)
  vendor         String    @db.VarChar(32)
  baseUrl        String    @map("base_url") @db.VarChar(512)
  apiKeyCipher   String    @map("api_key_cipher") @db.Text
  apiKeyPreview  String    @default("") @map("api_key_preview") @db.VarChar(64)
  lastVerifiedAt DateTime? @map("last_verified_at")
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  models Model[]

  @@map("provider")
}

model Model {
  id             Int       @id @default(autoincrement())
  modelKey       String    @unique @map("model_key") @db.VarChar(64)
  name           String    @db.VarChar(128)
  providerId     Int       @map("provider_id")
  modelIdent     String    @map("model_ident") @db.VarChar(191)
  description    String    @default("") @db.VarChar(500)
  enabled        Boolean   @default(true)
  capabilities   Json
  temperature    Float?
  maxTokens      Int?      @map("max_tokens")
  lastVerifiedAt DateTime? @map("last_verified_at")
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("model")
}
