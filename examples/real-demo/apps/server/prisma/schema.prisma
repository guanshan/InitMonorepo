generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id            Int        @id @default(autoincrement())
  userId        String     @unique @default(cuid()) @map("user_id")
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false) @map("email_verified")
  image         String     @default("") @db.VarChar(512)
  // Username is a logical identity in this system (UI uses it as a search
  // field, the API rejects duplicates with a 409). Enforced both in the
  // service (friendly pre-check, see UsersService) and at the database level
  // so two concurrent writes can't slip past the application check. Empty
  // defaults from earlier seeds are backfilled to `user_<id>` in the
  // matching migration before the unique index is created.
  username      String     @unique
  role          UserRole   @default(USER)
  department    Json       @default("[]")
  status        UserStatus @default(ACTIVE)
  lastLogin     DateTime?  @map("last_login")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime @map("expires_at")
  ipAddress String   @default("") @map("ip_address") @db.VarChar(64)
  userAgent String   @default("") @map("user_agent") @db.VarChar(512)
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id         Int      @id @default(autoincrement())
  accountId  String   @map("account_id") @db.VarChar(255)
  providerId String   @map("provider_id") @db.VarChar(128)
  userId     Int      @map("user_id")
  password   String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, providerId], name: "account_account_provider_uk")
  @@index([userId])
  @@map("account")
}

model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(128)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_setting")
}

model Provider {
  id             Int       @id @default(autoincrement())
  providerKey    String    @unique @map("provider_key") @db.VarChar(64)
  name           String    @db.VarChar(128)
  type           String    @db.VarChar(32)
  vendor         String    @db.VarChar(32)
  baseUrl        String    @map("base_url") @db.VarChar(512)
  apiKeyCipher   String    @map("api_key_cipher") @db.Text
  apiKeyPreview  String    @default("") @map("api_key_preview") @db.VarChar(64)
  lastVerifiedAt DateTime? @map("last_verified_at")
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  models Model[]

  @@map("provider")
}

model Model {
  id             Int       @id @default(autoincrement())
  modelKey       String    @unique @map("model_key") @db.VarChar(64)
  name           String    @db.VarChar(128)
  providerId     Int       @map("provider_id")
  modelIdent     String    @map("model_ident") @db.VarChar(191)
  description    String    @default("") @db.VarChar(500)
  enabled        Boolean   @default(true)
  capabilities   Json
  temperature    Float?
  maxTokens      Int?      @map("max_tokens")
  lastVerifiedAt DateTime? @map("last_verified_at")
  lastError      String?   @map("last_error") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("model")
}
