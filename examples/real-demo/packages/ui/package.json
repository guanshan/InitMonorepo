{
  "name": "@real-demo/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts --tsconfig tsconfig.build.json",
    "build-storybook": "storybook build --config-dir .storybook",
    "dev": "tsup src/index.tsx --format esm --dts --tsconfig tsconfig.build.json --watch",
    "lint": "eslint src .storybook --ext .ts,.tsx",
    "storybook": "storybook dev -p 16006 --config-dir .storybook",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@types/react": "^19.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.4"
  }
}
